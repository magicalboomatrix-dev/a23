# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=A23

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# OTP (for development, OTP is logged to console)
OTP_EXPIRY_MINUTES=5

# Fast2SMS (required in production for real OTP delivery)
SMS_PROVIDER=fast2sms
FAST2SMS_AUTHORIZATION_KEY=
FAST2SMS_ROUTE=q
FAST2SMS_LANGUAGE=english
FAST2SMS_OTP_TEMPLATE=Your A23 OTP is {{otp}}. Valid for {{expiryMinutes}} minutes.
FAST2SMS_SENDER_ID=
FAST2SMS_ENTITY_ID=
FAST2SMS_TEMPLATE_ID=

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Telegram Auto Deposit Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=a_random_secret_string_for_webhook_url
TELEGRAM_CHAT_ID=your_telegram_chat_id
BACKEND_PUBLIC_URL=https://yourdomain.com
